      "statement_1": "① digraph G1 { b -> c; c -> a; h -> g; f -> e; g -> e; a -> d; e -> d; }",
      "statement_2": "② digraph G2 { b -> c; c -> a; f -> e; h -> g; a -> d; e -> d; g -> d; }",
      "statement_3": "③ digraph G3 { c -> b; b -> d; f -> e; h -> g; d -> a; e -> a; g -> a; }",
      "statement_4": "④ digraph G4 { c -> b; f -> e; h -> g; b -> a; e -> d; g -> d; d -> a; }",
      "statement_5": "⑤ digraph G5 { c -> b; b -> d; h -> g; f -> e; g -> e; d -> a; e -> a; }"
