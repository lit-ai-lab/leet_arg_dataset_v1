      "statement_3": "③ digraph G3 { b -> d; c -> d; e -> g; f -> g; d -> a; g -> h; h -> a; }",
      "statement_4": "④ digraph G4 { b -> d; c -> d; e -> g; f -> g; g -> a; d -> h; a -> h; }",
      "statement_5": "⑤ digraph G5 { b -> h; c -> h; d -> h; e -> h; f -> h; g -> h; h -> a; }"
